FLASK_ENV=development
SECRET_KEY=change_me_in_production
DATABASE_URL=sqlite:///gourmen_dev.db
TZ=Europe/Zurich
TWOFA_ISSUER=Gourmen
CRYPTO_KEY=your_fernet_key_here
SENSITIVE_ACCESS_TTL_SECONDS=300
INIT_ADMIN_EMAIL=admin@gourmen.ch
INIT_ADMIN_PASSWORD=change_me_admin
SECURITY_CSP=default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:
RATE_LIMIT_LOGIN=5 per minute
RATE_LIMIT_STEPUP=5 per minute
MAIL_FROM_ADDRESS=kontakt@gourmen.ch
MAIL_REPLY_TO=kontakt@gourmen.ch
# Transaktionale Mails: auf Railway Hobby ist ausgehender SMTP blockiert.
# Production: Resend (HTTPS). Lokal optional SMTP.
# RESEND_API_KEY=re_...
# MAIL_HTTP_TIMEOUT_SECONDS=15
MAIL_SMTP_HOST=mail.infomaniak.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=kontakt@gourmen.ch
MAIL_SMTP_PASSWORD=change_me
MAIL_SMTP_USE_TLS=true
MAIL_SMTP_USE_SSL=false
MAIL_SMTP_TIMEOUT_SECONDS=3
MAIL_SMTP_MAX_IPV4_ATTEMPTS=1

# Google Maps API Keys
# GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
# GOOGLE_MAPS_API_KEY=your_backend_google_maps_api_key_here
# GOOGLE_MAPS_API_KEY_FRONTEND=your_frontend_google_maps_api_key_here 